@page "/Admin/Posts/Edit/{id}"
@model PublishCoreStandard.Web.Areas.Admin.Pages.Posts.EditModel
@{
    ViewData["Title"] = "Edit Post";
}

<h1>Edit Post</h1>

<form method="post">
    <input type="hidden" asp-for="Post.Id" />
    <div class="form-group">
        <label asp-for="Post.Title"></label>
        <input asp-for="Post.Title" class="form-control" />
        <span asp-validation-for="Post.Title" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Post.Slug"></label>
        <input asp-for="Post.Slug" class="form-control" />
        <span asp-validation-for="Post.Slug" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Post.Excerpt"></label>
        <textarea asp-for="Post.Excerpt" class="form-control" rows="2"></textarea>
        <span asp-validation-for="Post.Excerpt" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Post.Content">Content (Markdown or HTML)</label>
        <textarea asp-for="Post.Content" class="form-control" rows="15">@Model.Post.Content</textarea>
        <span asp-validation-for="Post.Content" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Post.Author"></label>
        <input asp-for="Post.Author" class="form-control" />
        <span asp-validation-for="Post.Author" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Post.TagsString">Tags (comma separated)</label>
        <input asp-for="Post.TagsString" class="form-control" value="@Model.Post.TagsString" />
    </div>
    <div class="form-group">
        <label asp-for="Post.CategoryId">Category</label>
        <select asp-for="Post.CategoryId" asp-items="Model.Categories" class="form-control">
            <option value="">-- None --</option>
        </select>
    </div>
    <div class="form-group">
        <label asp-for="Post.PublishedDate"></label>
        <input asp-for="Post.PublishedDate" class="form-control" value="@Model.Post.PublishedDate.ToString("yyyy-MM-ddTHH:mm")" />
    </div>
    <div class="form-group form-check">
        <input asp-for="Post.IsPublished" class="form-check-input" />
        <label asp-for="Post.IsPublished" class="form-check-label">Published</label>
    </div>
    <button type="submit" class="btn btn--primary">Save</button>
    <a asp-page="Index" class="btn btn--secondary">Cancel</a>
</form>

