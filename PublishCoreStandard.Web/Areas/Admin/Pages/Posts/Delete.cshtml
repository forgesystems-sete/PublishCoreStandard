@page "/Admin/Posts/Delete/{id}"
@model PublishCoreStandard.Web.Areas.Admin.Pages.Posts.DeleteModel
@{
    ViewData["Title"] = "Delete Post";
}

<h1>Delete Post</h1>
<p>Are you sure you want to delete this post?</p>
<dl>
    <dt>Title</dt>
    <dd>@Model.Post.Title</dd>
    <dt>Slug</dt>
    <dd>@Model.Post.Slug</dd>
</dl>

<form method="post">
    <button type="submit" class="btn btn--danger">Delete</button>
    <a asp-page="/Admin/Posts" class="btn btn--secondary">Cancel</a>
</form>
