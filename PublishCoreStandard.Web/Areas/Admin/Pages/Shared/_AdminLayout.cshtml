@{
    Layout = "/Pages/Shared/_Layout.cshtml";
}
@section Head {
    @RenderSection("Head", required: false)
}
@section Scripts {
    @RenderSection("Scripts", required: false)
}

<div class="admin-container" style="display: flex; min-height: calc(100vh - 120px);">
    <aside class="admin-sidebar" style="width: 250px; background: var(--color-bg-alt); border-right: 1px solid var(--color-border); padding: var(--space-4);">
        <h3>Admin Menu</h3>
        <ul style="list-style: none; padding: 0;">
            <li><a asp-area="Admin" asp-page="/Index">Dashboard</a></li>
            <li><a asp-area="Admin" asp-page="/Posts/Index">Posts</a></li>
            <li><a asp-area="Admin" asp-page="/Categories/Index">Categories</a></li>
            <li><a asp-area="Admin" asp-page="/Settings">Settings</a></li>
            <li><hr /></li>
            <li>
                <form asp-area="Identity" asp-page="/Account/Logout" method="post" style="display:inline;">
                    <button type="submit" class="btn btn--secondary" style="width:100%;">Logout</button>
                </form>
            </li>
        </ul>
    </aside>
    <main class="admin-content" style="flex:1; padding: var(--space-4);">
        @RenderBody()
    </main>
</div>

