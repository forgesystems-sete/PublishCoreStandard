@page "/Admin/Categories/Edit/{id}"
@model PublishCoreStandard.Web.Areas.Admin.Pages.Categories.EditModel
@{
    ViewData["Title"] = "Edit Category";
}
<h1>Edit Category</h1>
<form method="post">
    <input type="hidden" asp-for="Category.Id" />
    <div class="form-group"><label asp-for="Category.Name"></label><input asp-for="Category.Name" class="form-control" /></div>
    <div class="form-group"><label asp-for="Category.Slug"></label><input asp-for="Category.Slug" class="form-control" /></div>
    <div class="form-group"><label asp-for="Category.Description"></label><textarea asp-for="Category.Description" class="form-control"></textarea></div>
    <button type="submit" class="btn btn--primary">Save</button>
</form>

