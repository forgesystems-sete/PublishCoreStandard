@page "/Admin/Categories"
@model PublishCoreStandard.Web.Areas.Admin.Pages.Categories.IndexModel
@{
    ViewData["Title"] = "Manage Categories";
}

<h1>Categories</h1>
<p><a asp-page="Create" class="btn btn--primary">Create New</a></p>
<table class="table">
    <thead><tr><th>Name</th><th>Slug</th><th>Actions</th></tr></thead>
    <tbody>
    @foreach (var cat in Model.Categories)
    {
        <tr>
            <td>@cat.Name</td>
            <td>@cat.Slug</td>
            <td>
                <a asp-page="Edit" asp-route-id="@cat.Id">Edit</a> |
                <a asp-page="Delete" asp-route-id="@cat.Id">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>

